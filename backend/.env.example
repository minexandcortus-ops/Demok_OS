# Configuration de la base de données
DATABASE_URL=postgresql://user:password@localhost:5432/demok_db

# Sécurité & Auth
JWT_SECRET=votre_cle_secrete_jwt_tres_longue
VOTE_SECRET=votre_cle_de_hachage_anonyme_tres_longue

# Redis (Optionnel pour le cache)
REDIS_URL=redis://localhost:6379

# Mistral AI (Obligatoire pour les résumés automatiques)
MISTRAL_API_KEY=votre_cle_mistral_ici
MISTRAL_MODEL=mistral-small-latest

# Configuration Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=contact@votre-domaine.com
SMTP_PASSWORD=votre_mot_de_passe_smtp
SMTP_FROM=contact@votre-domaine.com

# URL Frontend (pour les liens dans les emails)
FRONTEND_URL=http://localhost:3000
