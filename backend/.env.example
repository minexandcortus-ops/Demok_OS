# Database
DATABASE_URL=postgresql://demok_user:demok_password@localhost:5432/demok_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=demok_user
DATABASE_PASSWORD=demok_password
DATABASE_NAME=demok_db

# Security Secrets
JWT_SECRET=YOUR_JWT_SECRET_HERE
VOTE_SECRET=YOUR_VOTE_SECRET_HERE
ADMIN_KEY=YOUR_ADMIN_KEY_HERE

# Notifications (Firebase Admin SDK JSON path)
GOOGLE_APPLICATION_CREDENTIALS=./demok-firebase-service-account.json

# Redis (For queues)
REDIS_URL=redis://localhost:6379

# Mistral AI (Optional, for gamification)
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY_HERE
MISTRAL_MODEL=mistral-small-latest

# Email Configuration (SMTP)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=465
SMTP_USER=contact@your-domain.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_FROM=contact@your-domain.com
FRONTEND_URL=http://localhost:3000
